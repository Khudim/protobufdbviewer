<idea-plugin>
    <id>com.khudim.protobufdbviewer</id>
    <name>Protobuf DB Viewer</name>
    <vendor email="dmitriykhud@gmail.com">Independent</vendor>

    <description><![CDATA[
      Decode protobuf-encoded binary values directly from IntelliJ IDEA database result grids.
      Configure one or more directories containing .proto files, select a binary cell, choose a protobuf message,
      and inspect the decoded value as formatted JSON in a live preview tool window.
    ]]></description>

    <depends>com.intellij.modules.platform</depends>
    <depends>com.intellij.database</depends>

    <extensions defaultExtensionNs="com.intellij">
        <projectConfigurable
                parentId="tools"
                id="com.khudim.protobufdbviewer.settings"
                displayName="Protobuf DB Viewer"
                instance="com.khudim.protobufdbviewer.ProtobufSettingsConfigurable"/>
        <toolWindow
                id="Protobuf Preview"
                anchor="right"
                canCloseContents="false"
                factoryClass="com.khudim.protobufdbviewer.ProtobufPreviewToolWindowFactory"/>
    </extensions>

    <actions>
        <action id="com.khudim.protobufdbviewer.ViewAsProtobufAction"
                class="com.khudim.protobufdbviewer.ViewAsProtobufAction"
                text="View as Protobuf"
                description="Decode the selected binary cell using a protobuf message">
            <add-to-group group-id="Console.TableResult.PopupGroup" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
